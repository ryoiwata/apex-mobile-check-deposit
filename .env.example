# Mobile Check Deposit — Environment Variables
# Copy to .env and fill in values before running docker compose.
# The .env file is gitignored and must never be committed.

# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://mcd:mcd@localhost:5432/mcd?sslmode=disable
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Storage ───────────────────────────────────────────────────────────────────
IMAGE_STORAGE_DIR=./data/images
SETTLEMENT_OUTPUT_DIR=./output/settlement

# ── Business Rules ────────────────────────────────────────────────────────────
RETURN_FEE_CENTS=3000        # $30.00 return fee

# ── Auth (demo tokens — replace with real secrets in production) ──────────────
INVESTOR_TOKEN=tok_investor_test
OPERATOR_TOKEN=tok_operator_test

# ── Settlement ────────────────────────────────────────────────────────────────
MAX_SETTLEMENT_RETRIES=3
